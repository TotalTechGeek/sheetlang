{
  "name": "sheetlang",
  "version": "0.1.1",
  "description": "Excel-like formula language that compiles to JSON Logic (via Peggy) and executes on json-logic-engine — over arbitrary data, not just a grid.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build:parser": "node scripts/build-parser.js",
    "build": "node scripts/build.js",
    "prepublishOnly": "npm run build && npm test",
    "pretest": "npm run build:parser",
    "test": "node --test test/*.test.js",
    "demo": "npm run build:parser && node examples/demo.js",
    "bench": "npm run build:parser && node examples/bench.js"
  },
  "keywords": [
    "excel",
    "formula",
    "formulas",
    "spreadsheet",
    "json-logic",
    "json-logic-engine",
    "peggy",
    "parser",
    "expression",
    "rules-engine"
  ],
  "license": "MIT",
  "dependencies": {
    "json-logic-engine": "^5.0.7"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "peggy": "^5.1.0"
  }
}
